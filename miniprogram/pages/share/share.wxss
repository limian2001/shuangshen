.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  min-height: 100vh;
  background: #f7f6f3;
}

.icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 16rpx;
  text-align: center;
}

.desc {
  font-size: 28rpx;
  color: #6b6b8d;
  text-align: center;
  line-height: 1.7;
  margin-bottom: 60rpx;
  padding: 0 20rpx;
}

.highlight {
  color: #534ab7;
  font-weight: 600;
}

.share-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.share-btn.primary {
  background: #534ab7;
  color: #fff;
}

.share-btn.secondary {
  background: #fff;
  color: #534ab7;
  border: 2rpx solid #534ab7;
}

.circle-hint {
  font-size: 24rpx;
  color: #9999b3;
  text-align: center;
  margin-bottom: 40rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  width: 100%;
  box-sizing: border-box;
  line-height: 1.6;
}
