/* 登录页样式 */
.container {
  height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 80rpx 60rpx 80rpx;
  background: #f7f6f3;
  overflow: hidden;
}

.logo-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  margin-top: 0;
}

.logo-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 30rpx;
  background: #534AB7;
  color: #fff;
  font-size: 56rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(83, 74, 183, 0.3);
}

.logo-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #534AB7;
  letter-spacing: 4rpx;
}

.logo-sub {
  font-size: 26rpx;
  color: #999;
  letter-spacing: 1rpx;
}

.btn-wrap {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.checking-tip {
  font-size: 28rpx;
  color: #999;
}

/* 昵称输入框 */
.input-wrap {
  width: 100%;
  background: #fff;
  border-radius: 16rpx;
  padding: 0 32rpx;
  box-sizing: border-box;
  border: 1rpx solid #e8e8e8;
}

.nickname-input {
  width: 100%;
  height: 88rpx;
  font-size: 28rpx;
  color: #333;
}

.input-placeholder {
  color: #bbb;
}

/* 手机号授权按钮 */
.phone-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  background: #534AB7;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(83, 74, 183, 0.35);
  margin: 0;
}

.phone-btn[disabled] {
  opacity: 0.7;
}

.tip {
  font-size: 22rpx;
  color: #bbb;
  text-align: center;
}

.tip-sub {
  font-size: 20rpx;
  color: #ccc;
  text-align: center;
  margin-top: -10rpx;
}
