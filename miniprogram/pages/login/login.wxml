<!-- 登录页 -->
<view class="container">
  <view class="logo-wrap">
    <view class="logo-icon">言</view>
    <text class="logo-name">言己</text>
    <text class="logo-sub">你的 AI 数字分身</text>
  </view>

  <!-- 检查中（自动静默登录） -->
  <view class="btn-wrap" wx:if="{{step === 'checking'}}">
    <view class="checking-tip">正在登录…</view>
  </view>

  <!-- 需要手机号授权（新用户） -->
  <view class="btn-wrap" wx:if="{{step === 'need_phone'}}">
    <!-- 昵称输入（type="nickname" 可触发微信头像昵称填充） -->
    <view class="input-wrap">
      <input
        class="nickname-input"
        type="nickname"
        placeholder="你的昵称（可不填）"
        placeholder-class="input-placeholder"
        bindinput="onNicknameInput"
        value="{{nickname}}"
        maxlength="20"
      />
    </view>

    <!-- 隐私协议勾选（必须主动同意才能点按钮） -->
    <view class="agree-row">
      <checkbox-group bindchange="onAgreeChange">
        <label class="agree-label">
          <checkbox value="agreed" checked="{{agreed}}" color="#534AB7" />
          <text class="agree-text">我已阅读并同意</text>
          <text class="agree-link" bindtap="openTerms">《用户协议》</text>
          <text class="agree-text">和</text>
          <text class="agree-link" bindtap="openPrivacy">《隐私政策》</text>
        </label>
      </checkbox-group>
    </view>

    <!-- 授权手机号按钮（必须用 button open-type；未勾选协议时禁用） -->
    <button
      class="phone-btn"
      open-type="getPhoneNumber"
      bindgetphonenumber="onGetPhoneNumber"
      loading="{{loading}}"
      disabled="{{!agreed || loading}}"
    >
      手机号快捷登录
    </button>

    <text class="tip-sub">手机号仅用于账号识别，不会泄露</text>
  </view>
</view>
