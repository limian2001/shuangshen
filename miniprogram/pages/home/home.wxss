/* ─────────────────────────────────────────────
   首页落地页样式
───────────────────────────────────────────── */

.landing {
  min-height: 100vh;
  background: #f7f6f3;
}

/* ── Hero ── */
.hero {
  background: linear-gradient(160deg, #534AB7 0%, #7B6ED6 100%);
  padding: 80rpx 48rpx 64rpx;
  text-align: center;
  color: #fff;
}

.hero-logo {
  font-size: 64rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
  margin-bottom: 20rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.hero-sub {
  font-size: 26rpx;
  opacity: 0.85;
}

/* ── Demo 对话 ── */
.demo-section {
  margin: 40rpx 32rpx 0;
}

.demo-label {
  font-size: 26rpx;
  color: #888;
  text-align: center;
  margin-bottom: 24rpx;
}

.demo-chat {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.bubble-wrap {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
}

.bubble-wrap.right {
  justify-content: flex-end;
}

.bubble-wrap.left {
  justify-content: flex-start;
}

.avatar-dot {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #534AB7;
  color: #fff;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.bubble {
  max-width: 72%;
  padding: 20rpx 28rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.bubble-user {
  background: #534AB7;
  color: #fff;
  border-bottom-right-radius: 4rpx;
}

.bubble-ai {
  background: #f0effc;
  color: #333;
  border-bottom-left-radius: 4rpx;
}

/* ── 功能卡片 ── */
.features {
  margin: 40rpx 32rpx 0;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.feature-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.feature-icon {
  font-size: 52rpx;
  flex-shrink: 0;
}

.feature-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 6rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: #888;
  line-height: 1.5;
}

/* ── CTA ── */
.cta-section {
  margin: 56rpx 32rpx 0;
  text-align: center;
}

.cta-btn {
  background: #534AB7;
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 56rpx;
  padding: 0;
  height: 96rpx;
  line-height: 96rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(83, 74, 183, 0.36);
  width: 100%;
}

.cta-btn::after {
  border: none;
}

.cta-hint {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #aaa;
}

/* ── Footer ── */
.landing-footer {
  text-align: center;
  font-size: 24rpx;
  color: #ccc;
  padding: 48rpx 32rpx 80rpx;
}
