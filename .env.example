# ===========================
# 替身 (Shuangshen) 环境变量
# ===========================

# --- 应用 ---
FLASK_ENV=development
SECRET_KEY=dev-secret-key-change-in-production
PORT=5000

# --- 数据库 ---
# 开发环境使用 SQLite，生产换为 PostgreSQL
DATABASE_URL=sqlite:///./data/shuangshen.db

# --- LLM 配置 ---
# 当前默认使用 Claude (Anthropic)
# 可切换为: anthropic | openai | local
LLM_PROVIDER=anthropic

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (备用)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# 本地模型 (如 Ollama，备用)
LOCAL_LLM_BASE_URL=http://localhost:11434
LOCAL_LLM_MODEL=qwen2.5

# --- JWT ---
JWT_SECRET=jwt-secret-change-in-production
JWT_EXPIRE_HOURS=72

# --- 文件上传 ---
UPLOAD_FOLDER=./data/uploads
MAX_CONTENT_LENGTH_MB=50

# --- 语音克隆 (v0.2 启用) ---
# ELEVENLABS_API_KEY=
# FISH_AUDIO_API_KEY=
